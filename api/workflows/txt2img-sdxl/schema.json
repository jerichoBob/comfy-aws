{
  "description": "SDXL text-to-image generation",
  "params": {
    "checkpoint": {
      "node_id": "4",
      "input": "ckpt_name",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Model checkpoint filename (e.g. sd_xl_base_1.0.safetensors)"
    },
    "positive_prompt": {
      "node_id": "6",
      "input": "text",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Positive prompt describing the desired image"
    },
    "negative_prompt": {
      "node_id": "7",
      "input": "text",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Negative prompt for things to avoid"
    },
    "steps": {
      "node_id": "10",
      "input": "steps",
      "type": "integer",
      "required": false,
      "default": 20,
      "description": "Number of sampling steps"
    },
    "cfg": {
      "node_id": "10",
      "input": "cfg",
      "type": "number",
      "required": false,
      "default": 7.0,
      "description": "Classifier-free guidance scale"
    },
    "sampler_name": {
      "node_id": "10",
      "input": "sampler_name",
      "type": "string",
      "required": false,
      "default": "euler",
      "description": "KSampler sampler (e.g. euler, dpmpp_2m, dpmpp_sde)"
    },
    "scheduler": {
      "node_id": "10",
      "input": "scheduler",
      "type": "string",
      "required": false,
      "default": "normal",
      "description": "KSampler scheduler (e.g. normal, karras, exponential)"
    },
    "seed": {
      "node_id": "10",
      "input": "seed",
      "type": "integer",
      "required": false,
      "default": 42,
      "description": "Random seed for reproducibility"
    },
    "width": {
      "node_id": "11",
      "input": "width",
      "type": "integer",
      "required": false,
      "default": 1024,
      "description": "Output image width in pixels"
    },
    "height": {
      "node_id": "11",
      "input": "height",
      "type": "integer",
      "required": false,
      "default": 1024,
      "description": "Output image height in pixels"
    }
  }
}
